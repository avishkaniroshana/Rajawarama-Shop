package com.rajawarama.backend.entity;

import jakarta.persistence.*;
import lombok.Getter;
import lombok.NoArgsConstructor;
import lombok.Setter;
import org.hibernate.annotations.CreationTimestamp;
import org.hibernate.annotations.UpdateTimestamp;

import java.time.LocalDateTime;
import java.util.*;

@Entity
@Table(name = "dancing_group_package")
@Getter
@Setter
@NoArgsConstructor
public class DancingGroupPackage {

    @Id
    @GeneratedValue(strategy = GenerationType.UUID)
    @Column(name = "dancing_package_id", nullable = false, updatable = false)
    private UUID id;

    @Column(name = "dancing_package_name", nullable = false)
    private String name;

    @Column(name = "details", columnDefinition = "TEXT")
    private String details;

    // price field is REMOVED – now computed dynamically
    // NEW: Stored total price (updated automatically)
    @Column(name = "total_price", nullable = true)  // nullable for safety
    private Double totalPrice;

    @CreationTimestamp
    private LocalDateTime createdAt;

    @UpdateTimestamp
    private LocalDateTime updatedAt;

    @ManyToMany
    @JoinTable(
            name = "package_performer_type",
            joinColumns = @JoinColumn(name = "dancing_package_id"),
            inverseJoinColumns = @JoinColumn(name = "performer_type_id")
    )
    private List<DancingPerformerType> includedPerformers = new ArrayList<>();

    @ElementCollection
    @CollectionTable(name = "package_performer_quantity")
    @MapKeyJoinColumn(name = "performer_type_id")
    @Column(name = "quantity")
    private Map<UUID, Integer> quantities = new HashMap<>();

    // ────────────────────────────────────────────────
    // Computed total price – not stored in database
    // ────────────────────────────────────────────────


//    @Transient
//    public Double getTotalPrice() {
//        if (includedPerformers == null || includedPerformers.isEmpty()) {
//            return 0.0;
//        }
//
//        double sum = 0.0;
//        for (DancingPerformerType type : includedPerformers) {
//            Integer qty = quantities.getOrDefault(type.getId(), 0);
//            sum += qty * type.getPricePerUnit();
//        }
//        return sum;
//    }

    @Transient
    public Double getCalculatedTotalPrice() {
        if (includedPerformers == null || includedPerformers.isEmpty()) return 0.0;
        double sum = 0.0;
        for (DancingPerformerType type : includedPerformers) {
            Integer qty = quantities.getOrDefault(type.getId(), 0);
            sum += qty * type.getPricePerUnit();
        }
        return sum;
    }

    // Auto-update stored totalPrice + details
    public void updateCalculatedFields() {
        this.totalPrice = getCalculatedTotalPrice();
        autoGenerateDetails();  // your existing method
    }


    // Auto-generate readable description based on performers and quantities
    public void autoGenerateDetails() {
        if (includedPerformers == null || includedPerformers.isEmpty()) {
            this.details = "Custom dancing package – no performers selected yet.";
            return;
        }

        StringBuilder sb = new StringBuilder("Package includes:\n");
        for (DancingPerformerType type : includedPerformers) {
            Integer qty = quantities.getOrDefault(type.getId(), 0);
            if (qty > 0) {
                sb.append("• ")
                        .append(qty)
                        .append(" × ")
                        .append(type.getName())
                        .append(" (Rs. ")
                        .append(String.format("%.0f", type.getPricePerUnit()))
                        .append(" each)\n");
            }
        }
        sb.append("\nTotal estimated value: Rs. ")
                .append(String.format("%.0f", getTotalPrice()));

        this.details = sb.toString().trim();
    }
}


